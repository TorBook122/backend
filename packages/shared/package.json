{
  "name": "@torbook/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server/internal-auth": {
      "types": "./dist/server/internal-auth.d.ts",
      "import": "./dist/server/internal-auth.js"
    },
    "./server/http-client": {
      "types": "./dist/server/http-client.d.ts",
      "import": "./dist/server/http-client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "dev": "PORT=3011 tsx watch src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2"
  }
}
